# ---- DPT Home Care environment variables ----
# Copy this file to `.env.local` and fill in the values.

# AI Chat assistant (required for the chatbot to give live AI answers).
# Get a key from https://console.anthropic.com
# Without this, the chat widget still works but shows a "contact us" fallback.
ANTHROPIC_API_KEY=

# Optional: which Claude model the chatbot uses.
# Default is claude-opus-4-8 (most capable). For a simple website FAQ bot,
# claude-haiku-4-5 is far cheaper and works great — recommended for cost control.
# CHAT_MODEL=claude-haiku-4-5

# Password to view submitted quote requests at /admin/quotes
# CHANGE THIS to your own secret before going live.
ADMIN_KEY=dpt-admin-2026

# ---- Form emails (thank-you to visitor + new-lead alert to you) ----
# Without SMTP_USER/SMTP_PASS the site works fine, just no emails are sent.
#
# Easiest setup — Gmail:
#   1. Enable 2-Step Verification on your Google account
#   2. Create an App Password: https://myaccount.google.com/apppasswords
#   3. SMTP_USER = your Gmail address, SMTP_PASS = the 16-letter app password
# (Any other SMTP provider also works — set SMTP_HOST/SMTP_PORT accordingly.)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=

# Where new-lead alert emails go. Defaults to SMTP_USER if left empty.
ADMIN_NOTIFY_EMAIL=
